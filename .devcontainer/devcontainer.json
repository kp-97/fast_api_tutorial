{
    "name": "Fast API Tutorial",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python"
            ]
        }
    },
    "forwardPorts": [8000],
    "portsAttributes": {
        "8000": {
            "label": "FastAPI Server",
            "onAutoForward": "notify",
            "elevateIfNeeded": true,
            "visibility": "public" 
        }
    },
    "postStartCommand": "uvicorn main:app --host 0.0.0.0 --port 8000",
    "remoteUser": "nonroot"
}